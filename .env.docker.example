# ==========================================
# 1. CẤU HÌNH DATABASE (Dùng chung)
# ==========================================
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0...
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0...
MONGODB_DB_NAME=datn_db

# ==========================================
# 2. CẤU HÌNH GIAO TIẾP MẠNG NỘI BỘ DOCKER
# ==========================================
WEAVIATE_URL=http://weaviate:8080
WEAVIATE_API_KEY=

AI_SERVER_URL=http://ai-server:8000

# ==========================================
# 3. CẤU HÌNH CHO BACKEND (Spring Boot)
# ==========================================
AUTH_COOKIE_SECURE=false

# ==========================================
# 4. CẤU HÌNH AI PROVIDERS (Gemini/OpenAI/Groq)
# ==========================================
LLM_PROVIDER=google

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-3.1-flash-lite-preview
GOOGLE_TEMPERATURE=0

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=2048

# ==========================================
# 5. CẤU HÌNH LANGSMITH (Theo dõi Agent)
# ==========================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=rag_backend_datn
