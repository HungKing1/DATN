# =============================================================================
# RAG Backend Configuration
# =============================================================================

# --- Application ---
APP_NAME=RAG Backend
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Multi-Tenant ---
MULTI_TENANT_ENABLED=false
DEFAULT_TENANT_ID=default

# --- LLM Provider --- (options: groq, google, langchain_openai)
LLM_PROVIDER=groq

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=2048

# --- Google Gemini ---
GOOGLE_API_KEY=AIzaSyCW6Pnx6K8F2YJMQEXMRMXL9VSLqW4Smp8
GOOGLE_MODEL=gemini-2.5-flash
GOOGLE_TEMPERATURE=0.1

# --- Groq ---
GROQ_API_KEY=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
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=2048

# --- Embedding ---
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Vector Database ---
VECTOR_DB_PROVIDER=weaviate
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=
WEAVIATE_DEFAULT_COLLECTION=documents

# --- Chunking ---
CHUNKING_STRATEGY=recursive
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# --- Reranker ---
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=5

# --- Retrieval ---
RETRIEVAL_TOP_K=20
HYBRID_SEARCH_ALPHA=0.5

# --- Ingestion ---
INGESTION_STRATEGY=shared
MAX_BATCH_SIZE=100
MAX_DOCUMENT_SIZE_MB=50
